# ─── CallMate AI Hub — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─── Supabase (Frontend — exposed to browser) ───────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ─── Supabase (Backend — Vercel serverless only) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in your Stripe Dashboard > Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ─── Vapi (Voice AI) ────────────────────────────────────────────────────────
VAPI_WEBHOOK_SECRET=your_webhook_secret

# ─── Twilio (SMS Notifications) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
BUSINESS_OWNER_PHONE=+1...

# ─── Multi-tenant (MVP single-tenant override) ──────────────────────────────
BUSINESS_ID=your-business-uuid
